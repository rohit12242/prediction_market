# ─── Blockchain ──────────────────────────────────────────────────────────────
CHAIN_ID=31337
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Polygon RPC endpoints (get free keys at alchemy.com or infura.io)
RPC_URL_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
RPC_URL_POLYGON_AMOY=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Polygonscan API key (for contract verification) — https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# Contract addresses (auto-populated into deployments/*.json after running deploy scripts)
PREDICTION_MARKET_ADDRESS=
ORACLE_ADDRESS=
USDC_ADDRESS=

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fluxmarkets:fluxmarkets@localhost:5432/fluxmarkets
POSTGRES_USER=fluxmarkets
POSTGRES_PASSWORD=fluxmarkets
POSTGRES_DB=fluxmarkets
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=4000
JWT_SECRET=change-me-in-production-use-at-least-32-chars
JWT_EXPIRY=7d
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# ─── The Graph ───────────────────────────────────────────────────────────────
GRAPH_NODE_URL=http://localhost:8020
IPFS_URL=http://localhost:5001
SUBGRAPH_NAME=fluxmarkets/core

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/graphql
NEXT_PUBLIC_WS_URL=ws://localhost:4000/graphql
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_SUBGRAPH_URL=http://localhost:8000/subgraphs/name/fluxmarkets/core

